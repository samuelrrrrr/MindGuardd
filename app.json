{
  "expo": {
    "name": "MindGuard",
    "slug": "mindguard",
    "version": "1.0.0",
    "scheme": "mindguard",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#0a0e3f"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yourname.mindguard"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0e3f"
      },
      "package": "com.yourname.mindguard"
    },
    "plugins": [
      "expo-router",
      "expo-asset",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "e95d9124-200c-4ce2-82c4-6d307cbfba6c"
      }
    },
    "owner": "samuelrrrrr"
  }
}
